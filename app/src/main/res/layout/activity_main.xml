<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/soft_blue_bg"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Calculate your monthly electricity bill based on kWh usage and rebate percentage."
            android:textSize="14sp"
            android:textColor="#444444"
            android:gravity="center"
            android:paddingBottom="20dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Month"
            android:textStyle="bold"
            android:textColor="#000000" />

        <Spinner
            android:id="@+id/spinnerMonth"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="#FFFFFF" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Electricity Unit Used (kWh)"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginTop="15dp" />

        <EditText
            android:id="@+id/editTextUnit"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Enter 1 - 1000 kWh"
            android:inputType="number"
            android:background="#FFFFFF"
            android:textColor="#000000"
            android:textColorHint="#777777"
            android:padding="10dp" />

        <TextView
            android:id="@+id/textRebateValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Rebate: 0%"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginTop="15dp" />

        <SeekBar
            android:id="@+id/seekBarRebate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="5"
            android:progress="0" />

        <Button
            android:id="@+id/buttonCalculate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Calculate"
            android:layout_marginTop="20dp"
            android:backgroundTint="#0D47A1"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/textTotalCharges"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Total Charges: RM0.00"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:paddingTop="20dp" />

        <TextView
            android:id="@+id/textFinalCost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Final Cost: RM0.00"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#E65100"
            android:paddingTop="8dp" />

        <Button
            android:id="@+id/buttonSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Record"
            android:layout_marginTop="20dp"
            android:backgroundTint="#2E7D32"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/buttonHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="View History"
            android:layout_marginTop="10dp"
            android:backgroundTint="#F9A825"
            android:textColor="#000000" />

        <Button
            android:id="@+id/buttonAbout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="About"
            android:layout_marginTop="10dp"
            android:backgroundTint="#616161"
            android:textColor="#FFFFFF" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Notice: Electricity usage must be between 1 and 1000 kWh. Rebate must be between 0% and 5%."
            android:textSize="13sp"
            android:textColor="#555555"
            android:paddingTop="20dp" />

    </LinearLayout>
</ScrollView>