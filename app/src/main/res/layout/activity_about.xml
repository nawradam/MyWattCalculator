<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/soft_blue_bg"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="About MyWatt Calculator"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#0D47A1"
            android:gravity="center"
            android:paddingBottom="20dp" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imageStudent"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:src="@drawable/nooradam"
            android:contentDescription="Creator Picture"
            android:scaleType="centerCrop"
            android:layout_marginBottom="20dp"
            app:shapeAppearanceOverlay="@style/RoundedImageStyle"
            app:strokeColor="#0D47A1"
            app:strokeWidth="2dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Full Name: Noor Adam bin Mohamad Noor"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:paddingTop="10dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Student ID: 2024764707"
            android:textSize="16sp"
            android:textColor="#000000"
            android:paddingTop="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Course: ICT602 Mobile Technology and Development"
            android:textSize="16sp"
            android:textColor="#000000"
            android:paddingTop="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="App Description: MyWatt Calculator is an Android application that estimates monthly electricity bills based on electricity usage, selected month, and rebate percentage."
            android:textSize="15sp"
            android:textColor="#333333"
            android:paddingTop="18dp" />

        <TextView
            android:id="@+id/textGithubUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="GitHub URL: https://github.com/nawradam/MyWattCalculator"
            android:autoLink="web"
            android:linksClickable="true"
            android:textSize="15sp"
            android:textColor="#0D47A1"
            android:paddingTop="15dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="How to Use:\n\n1. Select the month.\n2. Enter electricity usage in kWh.\n3. Choose rebate percentage from 0% to 5%.\n4. Tap Calculate to view total charges and final cost.\n5. Tap Save Record to store the bill.\n6. Tap View History to view saved records.\n7. Tap any record to view details, update, or delete it."
            android:textSize="15sp"
            android:textColor="#000000"
            android:paddingTop="20dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="© 2026 Noor Adam bin Mohamad Noor. All rights reserved."
            android:textSize="14sp"
            android:textColor="#555555"
            android:gravity="center"
            android:paddingTop="25dp" />

        <Button
            android:id="@+id/buttonBackAbout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Back"
            android:layout_marginTop="20dp"
            android:backgroundTint="#616161"
            android:textColor="#FFFFFF" />

    </LinearLayout>
</ScrollView>